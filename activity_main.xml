// vai dentro do src>main>res> dentro da pasta layout 

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#898989">

    <!-- truco -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/black"
        android:gravity="center" >

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="TRUCO!"
            android:textColor="#FFFFFF"
            android:textSize="20sp"/>

    </LinearLayout>

    <!-- duplas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/texteq1"
            android:layout_width="132dp"
            android:layout_height="wrap_content"
            android:text="DUPLA 1:"
            android:textColor="#000000"
            android:layout_marginEnd="20dp"/>

        <TextView
            android:id="@+id/texteq2"
            android:layout_width="127dp"
            android:layout_height="wrap_content"
            android:text="DUPLA 2:"
            android:textColor="#000000"/>
    </LinearLayout>

    <!-- botõestruco -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/buttontruco"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TRUCO!" />

        <Button
            android:id="@+id/button6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SEIS!!"
            android:visibility="gone" />

        <Button
            android:id="@+id/button9"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NOVE!!!"
            android:visibility="gone"/>

        <Button
            android:id="@+id/button12"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="DOZE!!!!"
            android:visibility="gone" />


    </LinearLayout>

    <Button
        android:id="@+id/button1pteq1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+1 PONTO equipe1" />

    <Button
        android:id="@+id/buttondiminuirpteq1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="-1 PONTO equipe1" />

    <Button
        android:id="@+id/button1pteq2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+1 PONTO equipe2" />

    <Button
        android:id="@+id/buttondiminuirpteq2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="-1 PONTO equipe2" />
</LinearLayout>
